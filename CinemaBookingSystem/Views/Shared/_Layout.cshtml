<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>CinemaBooking</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body>
	
	<header>
		<nav class="navbar navbar-expand-lg navbar-dark bg-black shadow mb-4">
			<div class="container">
				<a class="navbar-brand fw-bold" asp-action="Index">
					<span class="text-primary"></span> CinemaBooking
				</a>
				<div class="navbar-nav me-auto">
					<a class="nav-link active" asp-controller="Home" asp-action="Index">Головна</a>
					<a class="nav-link" href="#">Фільми</a>
					<a class="nav-link" href="#">Про нас</a>
				</div>
				<div class="navbar-nav">
					<a class="btn btn-outline-danger btn-sm" asp-controller="Admin" asp-action="Index">Адмін панель</a>
				</div>
				<div class="navbar-nav p-2">
					<a class="btn btn-primary" asp-page="/Cart">Кошик</a>
				</div>
			</div>
		</nav>
		
	</header>
	<main>
		<div class="container d-flex">
			<div id="categories" class="col-3">
				<vc:navigation-menu />
			</div>
			<div col-9>
				@RenderBody()
			</div>
		</div>

		
	</main>
	<footer class="bg-light text-center text-muted py-4 mt-auto border-top">
		<div class="container">
			<p class="mb-0">&copy; 2026 - Система Бронювання Квитків - Дмитро Р.</p>
		</div>
	</footer>
	
</body>
</html>



