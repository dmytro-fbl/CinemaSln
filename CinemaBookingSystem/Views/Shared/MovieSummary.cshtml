@model CinemaBookingSystem.DataAccess.Models.Movie;

<div class="col">
	<div class="card h-100 shadow-sm border-0 bg-light">
		<div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
			<span class="h1">Фото</span>
		</div>

		<div class="card-body">
			<div class="d-flex justify-content-between mb-2">
				<span class="badge bg-primary">@Model.Genre</span>
				<small class="text-muted">@Model.ReleaseDate.ToString("dd.MM.yyyy")</small>

			</div>

			<h5 class="card-title fw-bold">@Model.Title</h5>
			<p class="card-text text-muted">@Model.Description</p>
		</div>

		<div class="card-footer bg-white border-0 pb-3">
			<div class="d-flex justify-content-between align-items-center">
				<span class="h5 mb-0 text-success fw-bold">@Model.TicketPrice.ToString("0.00") грн</span>
			</div>
			<form asp-page="/Cart" method="post">	
				<input type="hidden" name="movieId" value="@Model.MovieID" />
				<input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
				<span class="card-text">
					<button type="submit" class="btn btn-success btn-sm float-end">
						Вибрати квиток
					</button>
				</span>
			</form>
		</div>
	</div>
</div>