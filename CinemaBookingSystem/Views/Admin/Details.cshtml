@model Movie

<div class="container mt-4">
	<div class="card">
		<div class="card-header bg-info text-white">
			<h3>@Model.Title</h3>
		</div>
		<div class="card-body">
			<p>Опис: @Model.Description</p>
			<p>Жанр: @Model.Genre</p>
			<p>Дата виходу: @Model.ReleaseDate.ToShortDateString()</p>
			<hr />

			<h4>Розклад сеансів</h4>
			@if (Model.Showtimes.Any())
			{
				<ul class="list-group">
					@foreach (var session in Model.Showtimes)
					{
						<li class="list-group-item d-flex justify-content-between align-items-center">
							Сеанс: @session.SessionTime.ToString("dd.MM HH:mm")
							<span class="badge bg-primary rounded-pill">Зал №@session.HallNumber</span>
						</li>
					}
				</ul>
			}
			else
			{
				<div class="alert alert-warning">Сеансів для цього фільму поки немає.</div>
			}
		</div>
		<div class="card-footer">
			<a asp-action="Index" class="btn btn-secondary">Назад до списку</a>
			<a asp-action="Edit" asp-route-movieId="@Model.MovieID" class="btn btn-warning">Редагувати</a>
		</div>

	</div>
</div>