@using CinemaBookingSystem.DataAccess.Models
@model Movie

<div class="container mt-4">
	<h2>@ViewBag.Title</h2>

	@* <div asp-validation-summary="All" class="text-danger font-weight-bold"></div> *@

	<form action="Edit" method="post">
		<input type="hidden" asp-for="MovieID" />
		<div class="mb-3">
			<label asp-for="Title" class="form-label">Назва фільму: </label>
			<input asp-for="Title" class="form-control" />
			<span asp-validation-for="Title" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Description" class="form-label">Опис: </label>
			<textarea asp-for="Description" class="form-control" rows="3"></textarea>
			<span asp-validation-for="Description" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Genre" class="form-label">Жанр:</label>
			<input asp-for="Genre" class="form-control" />
			<span asp-validation-for="Genre" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="TicketPrice" class="form-label">Ціна квитка: </label>
			<input asp-for="TicketPrice" class="form-control" />
			<span asp-validation-for="TicketPrice" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="ReleaseDate" class="form-label">Дата виходу: </label>
			<input asp-for="ReleaseDate" class="form-control" />
			<span asp-validation-for="ReleaseDate" class="text-danger"></span>
		</div>
		<button type="submit" class="btn btn-primary">Зберегти</button>
		<a asp-action="Index" class="btn btn-secondary">Скасувати</a>
		</form>
</div>

